# ============================================================
# .env — committed to git (non-secret defaults)
# ============================================================
# This file is tracked by git. Only put non-secret values here.
# Prisma reads DATABASE_URL from this file.

# Database (SQLite for local — zero config; PostgreSQL for cloud)
DATABASE_URL=file:./data/wwv.db

# ============================================================
# .env.local — NOT committed (secrets & API keys)
# ============================================================
# Copy everything below into a new file called .env.local
# .env.local is gitignored and overrides .env values.

# Auth Secret (REQUIRED — generate with: openssl rand -hex 32)
# Must remain stable across restarts to preserve sessions and tokens.
# For Docker: also set this in the host environment or a .env file
# at the project root so docker-compose can inject it.
AUTH_SECRET=

# Cesium Ion Access Token (optional — get one free at https://ion.cesium.com/)
NEXT_PUBLIC_CESIUM_ION_TOKEN=

# Bing Maps API Key (Optional, for high-res imagery)
# Get your key at https://www.bingmapsportal.com/
NEXT_PUBLIC_BING_MAPS_KEY=

# Supabase Configuration (Optional — cloud-only features)
# Found in your Supabase Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DATABASE_URL=

# OpenSky Network — multi-account credential rotation
# Comma-separated clientId:clientSecret pairs.
# Example: OPENSKY_CREDENTIALS=acct1-id:acct1-secret,acct2-id:acct2-secret
OPENSKY_CREDENTIALS=

# ACLED API — Civil Unrest & Conflict data (free for non-commercial use)
# Register at https://developer.acleddata.com/ to obtain credentials.
# Data is updated weekly (Mondays) with global protest, riot, and violence events.
ACLED_EMAIL=
ACLED_PASSWORD=

# Marketplace Bridge Token — shared secret for marketplace → WWV install requests
# Generate any random string, then set the same value in the marketplace instance config.
WWV_BRIDGE_TOKEN=

# Default plugins enabled on boot for demo edition
# Comma-separated list of plugin IDs
NEXT_PUBLIC_DEMO_DEFAULT_PLUGINS=

# Edition: "local" | "cloud" | "demo"
NEXT_PUBLIC_WWV_EDITION=local

# Demo Admin Secret (demo edition only)
# Allows operator plugin management on the demo instance via x-wwv-admin-secret header.
# Generate any random string. Only set this on the demo deployment.
# WWV_DEMO_ADMIN_SECRET=
