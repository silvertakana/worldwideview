# Environment Variables Example

# Cesium Ion Access Token (Required for terrain and default imagery)
# Get your token at https://ion.cesium.com/
NEXT_PUBLIC_CESIUM_ION_TOKEN=

# Bing Maps API Key (Optional, for high-res imagery)
# Get your key at https://www.bingmapsportal.com/
NEXT_PUBLIC_BING_MAPS_KEY=

# Supabase Configuration (Required for persistence and historical data)
# Found in your Supabase Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenSky Network — multi-account credential rotation
# Comma-separated clientId:clientSecret pairs. Each account = 4,000 credits/day (~4.2h at 15s polling).
# Example: OPENSKY_CREDENTIALS=acct1-id:acct1-secret,acct2-id:acct2-secret
OPENSKY_CREDENTIALS=

# Legacy single-credential fallback (used if OPENSKY_CREDENTIALS is empty)
# OPENSKY_CLIENTID=
# OPENSKY_CLIENTSECRET=

# Military Aviation — adsb.fi open data API
# No API key required. Free endpoint: https://opendata.adsb.fi/api/v2/mil
# Rate limit: 1 request/second. For personal, non-commercial use.

