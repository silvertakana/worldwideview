{
  "name": "worldwideview",
  "version": "1.8.2",
  "private": true,
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "test-worktree": "node scripts/test-worktree.mjs",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('.next',{recursive:true,force:true})\"",
    "dev": "next dev --webpack",
    "dev:all": "npx concurrently \"pnpm dev\" \"pnpm --filter wwv-data-engine dev\"",
    "predev": "npx prisma migrate deploy && node scripts/copy-cesium.mjs",
    "copy-cesium": "node scripts/copy-cesium.mjs",
    "build": "next build --webpack",
    "start": "next start",
    "test": "vitest run",
    "start:backends": "pnpm --filter wwv-data-engine start",
    "dev:backends": "pnpm --filter wwv-data-engine dev",
    "clean:backends": "pnpm --filter wwv-data-engine clean:db",
    "db:reset": "npx prisma migrate reset --force"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/adapter-better-sqlite3": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@supabase/supabase-js": "^2.98.0",
    "@vercel/analytics": "^1.6.1",
    "@worldwideview/wwv-plugin-aviation": "workspace:*",
    "@worldwideview/wwv-plugin-borders": "workspace:*",
    "@worldwideview/wwv-plugin-camera": "workspace:*",
    "@worldwideview/wwv-plugin-civil-unrest": "workspace:*",
    "@worldwideview/wwv-plugin-conflict-events": "workspace:*",
    "@worldwideview/wwv-plugin-cyber-attacks": "workspace:*",
    "@worldwideview/wwv-plugin-daynight": "workspace:*",
    "@worldwideview/wwv-plugin-earthquakes": "workspace:*",
    "@worldwideview/wwv-plugin-gps-jamming": "workspace:*",
    "@worldwideview/wwv-plugin-international-sanctions": "workspace:*",
    "@worldwideview/wwv-plugin-iranwarlive": "workspace:*",
    "@worldwideview/wwv-plugin-maritime": "workspace:*",
    "@worldwideview/wwv-plugin-military-aviation": "workspace:*",
    "@worldwideview/wwv-plugin-satellite": "workspace:*",
    "@worldwideview/wwv-plugin-sdk": "workspace:*",
    "@worldwideview/wwv-plugin-surveillance-satellites": "workspace:*",
    "@worldwideview/wwv-plugin-undersea-cables": "workspace:*",
    "@worldwideview/wwv-plugin-wildfire": "workspace:*",
    "bcryptjs": "^3.0.3",
    "cesium": "^1.139.0",
    "cheerio": "^1.2.0",
    "hls.js": "^1.6.15",
    "insecam-api": "^0.0.3",
    "jose": "^6.2.2",
    "lucide-react": "^0.576.0",
    "next": "16.2.1",
    "next-auth": "^5.0.0-beta.30",
    "prisma": "^7.5.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-player": "^3.4.0",
    "resium": "1.19.4",
    "satellite.js": "^7.0.0",
    "tslib": "^2.8.1",
    "ws": "^8.14.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/cesium": "^1.70.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "copy-webpack-plugin": "^14.0.0",
    "jsdom": "^28.1.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "better-sqlite3",
      "esbuild",
      "prisma",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ]
  }
}
