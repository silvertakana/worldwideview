{
  "name": "worldwideview",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "clean": "node -e \"const fs=require('fs');fs.rmSync('.next',{recursive:true,force:true})\"",
    "dev": "next dev --webpack",
    "predev": "npx prisma migrate deploy && node scripts/copy-cesium.mjs",
    "copy-cesium": "node scripts/copy-cesium.mjs",
    "build": "next build --webpack",
    "start": "next start",
    "test": "vitest run"
  },
  "dependencies": {
    "@worldwideview/wwv-plugin-sdk": "*",
    "@worldwideview/wwv-plugin-aviation": "*",
    "@worldwideview/wwv-plugin-maritime": "*",
    "@worldwideview/wwv-plugin-wildfire": "*",
    "@worldwideview/wwv-plugin-borders": "*",
    "@worldwideview/wwv-plugin-camera": "*",
    "@worldwideview/wwv-plugin-military": "*",
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/adapter-better-sqlite3": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@supabase/supabase-js": "^2.98.0",
    "@vercel/analytics": "^1.6.1",
    "bcryptjs": "^3.0.3",
    "cesium": "^1.139.0",
    "cheerio": "^1.2.0",
    "hls.js": "^1.6.15",
    "insecam-api": "^0.0.3",
    "lucide-react": "^0.576.0",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "prisma": "^7.5.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-player": "^3.4.0",
    "resium": "^1.19.4",
    "tslib": "^2.8.1",
    "ws": "^8.14.2",
    "zustand": "^5.0.11"
