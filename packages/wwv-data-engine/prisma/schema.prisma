// This is your Prisma schema file for the WWV Data Engine
// It connects to Supabase to store historical timeline data.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("SUPABASE_DATABASE_URL")
}

model IranwarEvent {
  eventId   String   @id @map("event_id")
  payload   String   // Stored as JSON string to mirror existing SQLite structure
  timestamp BigInt
  fetchedAt BigInt   @map("fetched_at")

  @@index([timestamp])
  @@map("iranwar_events")
}

model Earthquake {
  id        String   @id
  payload   String   // Stored as JSON string
  sourceTs  BigInt   @map("source_ts")
  fetchedAt BigInt   @map("fetched_at")

  @@index([sourceTs])
  @@map("earthquakes")
}

model Wildfire {
  id        String   @id
  payload   String   // Stored as JSON string
  sourceTs  BigInt   @map("source_ts")
  fetchedAt BigInt   @map("fetched_at")

  @@index([sourceTs])
  @@map("wildfires")
}

model MaritimeHistory {
  mmsi      String
  ts        BigInt
  lat       Float
  lon       Float
  heading   Float?   @map("hdg")
  speed     Float?   @map("spd")
  fetchedAt BigInt   @map("fetched_at")

  @@id([mmsi, ts])
  @@index([ts])
  @@map("maritime_history")
}

model AviationHistory {
  icao24    String
  ts        BigInt
  lat       Float?
  lon       Float?
  alt       Float?
  heading   Float?   @map("hdg")
  speed     Float?   @map("spd")
  fetchedAt BigInt   @map("fetched_at")

  @@id([icao24, ts])
  @@index([ts])
  @@map("aviation_history")
}

model MilitaryAviationHistory {
  hex       String
  ts        BigInt
  lat       Float?
  lon       Float?
  alt       Float?
  heading   Float?   @map("hdg")
  speed     Float?   @map("spd")
  fetchedAt BigInt   @map("fetched_at")

  @@id([hex, ts])
  @@index([ts])
  @@map("military_aviation_history")
}
